# --- Strava OAuth / API ---
# OAuth App client id. Safe to expose to browser when needed.
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_client_id

# OAuth App client secret. Server-side only.
STRAVA_CLIENT_SECRET=your_client_secret

# Redirect URI registered in Strava OAuth app settings.
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Space/comma-separated scope list used for OAuth authorization request.
STRAVA_SCOPES=read,activity:read_all

# Strava API base URL (override only when needed)
STRAVA_API_BASE_URL=https://www.strava.com/api/v3
